{
  "manifest_version": 3,
  "name": "Okta Auto-Login",
  "version": "1.0.0",
  "description": "Automates Okta SAML login flow by auto-filling credentials and triggering push notifications",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "*://*.okta.com/*",
    "*://*.oktapreview.com/*",
    "*://*.okta-emea.com/*",
    "http://127.0.0.1/*",
    "*://*.github.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["crypto.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.okta.com/*",
        "*://*.oktapreview.com/*",
        "*://*.okta-emea.com/*"
      ],
      "js": ["crypto.js", "content.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["*://*.github.com/*"],
      "js": ["content-github.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
